# Database
DATABASE_USER=user
DATABASE_PASSWORD=password
DATABASE_DB=music_server
DATABASE_PORT=5432
DATABASE_DATA_PATH=./data/postgres

# Valkey
VALKEY_PORT=6379
VALKEY_DATA_PATH=./data/valkey

# API & Worker
PORT=3000
SECRET_STORE_KEY=replace-this-with-a-secure-key
MUSIC_LIBRARY_PATH=/music
ALBUM_ART_CACHE_PATH=/data/album-art-cache
SCAN_JOB_ATTEMPTS=3
SCAN_JOB_BACKOFF_MS=2000

# AI Configuration
LLM_PROVIDER=ollama
LLM_ENDPOINT=http://localhost:11434
LLM_MODEL_NAME=llama3
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024
AI_JOB_ATTEMPTS=3
AI_JOB_BACKOFF_MS=5000

# Admin UI
VITE_API_URL=http://localhost:3000
ADMIN_UI_PORT=3001
